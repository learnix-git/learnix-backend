datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  TEACHER
  STUDENT
  ADMIN
}

enum Status {
  PENDING   
  COMPLETED 
  FAILED    
  CANCELLED 
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  courseId    String?    
  bookingId   String?     
  amount      Int         
  status      Status      @default(PENDING)
  gateway     String      @default("VNPAY")
  created     DateTime    @default(now())
  updated     DateTime    @updatedAt

  userRef     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseRef   Course?     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  bookingRef  Booking?    @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("orders")
}

model User {
  id       String    @id @default(cuid())
  email    String    @unique
  password String
  name     String
  gender   Int       @default(0)
  avatar   String?
  role     Role      @default(STUDENT)
  active   Boolean   @default(true)
  login    DateTime?
  created  DateTime  @default(now())
  updated  DateTime  @updatedAt
  deleted  DateTime?
  token    String?  
  expire   DateTime?
  provider String    @default("credentials")
  
  courses       Course[]
  banks         Bank[]
  plans         Plan[]
  notifications Notification[]
  members       Member[]        @relation("studentRef")
  submissions   Submission[]
  orders        Order[]
  cccd          String?   
  degree        String?   
  major         String?   
  bio           String?   
  fee           Float?    
  phone         String?   
  posts         Post[]
  teachingRef   Booking[]       @relation("TeacherBookings")
  bookingRef    Booking[]       @relation("StudentBookings")

  @@map("users")
}

model Course {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  description String?
  teacher     String
  thumbnail   String?  
  feed        Json      @default("[]")
  fee         Float     @default(0)
  grade       Int       @default(1)
  active      Boolean   @default(true)
  status      Boolean   @default(false)
  created     DateTime  @default(now())
  updated     DateTime  @updatedAt
  deleted     DateTime?
  rating      Float     @default(0)

  teacherRef  User      @relation(fields: [teacher], references: [id], onDelete: Cascade)
  members     Member[]  @relation("courseRef")
  exams       Exam[]
  orders      Order[]
  chapters    Chapter[]

  @@map("courses")
}

model Chapter {
  id       String   @id @default(cuid())
  title    String
  courseId String
  created  DateTime @default(now())

  courseRef Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]

  @@map("chapters")
}

model Lesson {
  id        String   @id @default(cuid())
  title     String
  video     String?  
  content   String?  
  chapterId String
  created   DateTime @default(now())

  chapterRef Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@map("lessons")
}

model Member {
  id        String   @id @default(cuid())
  course    String
  student   String
  role      String   @default("STUDENT")
  joined    DateTime @default(now())

  courseRef    Course    @relation("courseRef", fields: [course], references: [id], onDelete: Cascade)
  studentRef   User      @relation("studentRef", fields: [student], references: [id], onDelete: Cascade)

  @@unique([course, student])
  @@map("members")
}

model Post {
  id          String   @id @default(cuid())
  userId      String   
  title       String   
  content     String   
  type        String   
  subject     String   
  budget      Float    
  address     String?  
  contact     String?  
  created     DateTime @default(now())
  updated     DateTime @updatedAt

  userRef     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tutor_posts")
}

model Booking {
  id          String   @id @default(cuid())
  teacherId   String   
  studentId   String   
  start       DateTime?
  schedule    String?
  online      Boolean  @default(true) 
  address     String?  
  meet        String?  
  status      String   @default("PENDING") 
  fee         Float    
  created     DateTime @default(now())
  updated     DateTime @updatedAt

  teacherRef  User     @relation("TeacherBookings", fields: [teacherId], references: [id], onDelete: Cascade)
  studentRef  User     @relation("StudentBookings", fields: [studentId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@map("bookings")
}

model Bank {
  id          String    @id @default(cuid())
  name        String
  subject     String
  description String?
  teacher     String
  public      Boolean   @default(false)
  created     DateTime  @default(now())
  updated     DateTime  @updatedAt
  deleted     DateTime?

  teacherRef User       @relation(fields: [teacher], references: [id], onDelete: Cascade)
  questions  Question[]

  @@map("banks")
}

model Question {
  id         String    @id @default(cuid())
  bank       String
  content    String
  type       String    @default("MCQ")
  difficulty String    @default("MEDIUM")
  topic      String?
  options    Json?
  solution   Json?
  points     Float     @default(1.0)
  active     Boolean   @default(true)
  created    DateTime  @default(now())
  updated    DateTime  @updatedAt
  deleted    DateTime?

  bankRef Bank @relation(fields: [bank], references: [id], onDelete: Cascade)

  @@map("questions")
}

model Exam {
  id          String    @id @default(cuid())
  title       String
  description String?
  duration    Int
  threshold   Float     @default(5.0)
  teacher     String
  course      String?
  questions   Json      @default("[]")
  config      Json      @default("{}")
  status      String    @default("DRAFT")
  start       DateTime?
  end         DateTime?
  created     DateTime  @default(now())
  updated     DateTime  @updatedAt
  deleted     DateTime?

  courseRef    Course?      @relation(fields: [course], references: [id], onDelete: SetNull)
  submissions  Submission[]

  @@map("exams")
}

model Submission {
  id        String    @id @default(cuid())
  exam      String
  student   String
  start     DateTime  @default(now())
  submitted DateTime?
  elapsed   Int       @default(0)
  cheats    Int       @default(0)
  logs      Json?     @default("[]")
  answers   Json?     @default("[]")
  status    String    @default("IN_PROGRESS")
  created   DateTime  @default(now())
  updated   DateTime  @updatedAt

  examRef    Exam   @relation(fields: [exam], references: [id], onDelete: Cascade)
  studentRef User   @relation(fields: [student], references: [id], onDelete: Cascade)
  scoreRef   Score?

  @@unique([exam, student])
  @@map("submissions")
}

model Score {
  id         String   @id @default(cuid())
  student    String
  exam       String
  course     String?
  submission String   @unique
  total      Float    @default(0)
  max        Float    @default(10.0)
  passed     Boolean  @default(false)
  feedback   String?
  graded     DateTime @default(now())
  created    DateTime @default(now())
  updated    DateTime @updatedAt

  submissionRef Submission @relation(fields: [submission], references: [id], onDelete: Cascade)

  @@map("scores")
}

model Plan {
  id        String    @id @default(cuid())
  user      String
  title     String
  subject   String?
  content   Json
  status    String    @default("ACTIVE")
  completed DateTime?
  created   DateTime  @default(now())
  updated   DateTime  @updatedAt

  userRef User @relation(fields: [user], references: [id], onDelete: Cascade)

  @@map("plans")
}

model Notification {
  id      String   @id @default(cuid())
  user    String
  title   String
  message String?
  type    String   @default("SYSTEM")
  read    Boolean  @default(false)
  opened  DateTime?
  created DateTime @default(now())

  userRef User @relation(fields: [user], references: [id], onDelete: Cascade)

  @@map("notifications")
}