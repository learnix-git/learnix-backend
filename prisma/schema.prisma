datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Status {
  PENDING
  PROCESSING
  READY
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
  DRAFT
  PUBLISHED
  ARCHIVED
  ACTIVE
  SUSPENDED
  EXPIRED
  VERIFIED
  REJECTED
  RESOLVED
  AWAITING
  CONFIRMED
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL
}

enum Format {
  VIDEO
  TEXT
  QUIZ
  ASSIGNMENT
}

enum Method {
  PERCENTAGE
  FIXED
}

enum Access {
  ALL
  FREE
  PREMIUM
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Mode {
  ONLINE
  OFFLINE
}

enum Type {
  PURCHASE
  DEPOSIT
  FINAL
}

model User {
  id       String    @id @default(cuid())
  email    String    @unique
  password String
  name     String
  role     Role      @default(STUDENT)
  gender   Gender    @default(OTHER)
  avatar   String?
  active   Boolean   @default(true)
  phone    String?
  login    DateTime?
  token    String?
  expire   DateTime?
  attempts Int       @default(0)
  blocked  DateTime?
  secured  Boolean   @default(false)
  secret   String?
  created  DateTime  @default(now())
  updated  DateTime  @updatedAt
  deleted  DateTime?
  provider String    @default("credentials")

  student Student?
  teacher Teacher?

  sessions      Session[]
  wallets       Wallet[]
  notifications Notification[]
  orders        Order[]
  usages        Usage[]
  chats1        Chat[]         @relation("UserOne")
  chats2        Chat[]         @relation("UserTwo")
  messages      Message[]
  reports1      Report[]       @relation("Creator")
  reports2      Report[]       @relation("Target")
  audits        Audit[]
}

model Student {
  id      String   @id @default(cuid())
  account String   @unique
  created DateTime @default(now())
  updated DateTime @updatedAt

  user User @relation(fields: [account], references: [id], onDelete: Cascade)

  enrolls  Enrollment[]
  progress Progress[]
  cart     Cart?
  subs     Submission[]
  tasks    Task[]
  plans    Plan[]
  votes    Vote[]
  comments Comment[]
  reviews  Review[]
  favs     Favorite[]
  follows  Follow[]
  certs    Certificate[]
  bookings Booking[]     @relation("StudentBookings")
}

model Teacher {
  id      String @id @default(cuid())
  account String @unique

  bio      String?  @db.Text
  cccd     String?  @unique
  degree   String?
  major    String?
  website  String?
  github   String?
  linkedin String?
  rate     Decimal  @default(0.00) @db.Decimal(12, 2)
  video    String?
  verified Status   @default(PENDING)
  years    Int      @default(0)
  modes    Mode[]
  rating   Decimal  @default(0.00) @db.Decimal(3, 2)
  reviews  Int      @default(0)
  students Int      @default(0)
  created  DateTime @default(now())
  updated  DateTime @updatedAt

  user User @relation(fields: [account], references: [id], onDelete: Cascade)

  courses  Course[]
  banks    Bank[]
  exams    Exam[]
  posts    Post[]
  bids     Bid[]
  skills   Skill[]
  schedule Schedule[]
  timeoffs Timeoff[]
  coupons  Coupon[]
  reviewed Review[]   @relation("TeacherReviews")
  bookings Booking[]  @relation("TeacherBookings")
  follows  Follow[]
}

model Session {
  id      String   @id @default(cuid())
  owner   String
  refresh String   @unique
  agent   String?
  ip      String?
  expire  DateTime
  revoked Boolean  @default(false)
  created DateTime @default(now())

  user User @relation(fields: [owner], references: [id], onDelete: Cascade)
}

model Wallet {
  id      String   @id @default(cuid())
  owner   String
  bank    String
  account String
  holder  String
  main    Boolean  @default(false)
  created DateTime @default(now())
  updated DateTime @updatedAt

  user User @relation(fields: [owner], references: [id], onDelete: Cascade)
}

model Subject {
  id     String  @id @default(cuid())
  name   String  @unique
  slug   String  @unique
  skills Skill[]
}

model Skill {
  tutor  String
  topic  String
  grades String[]

  teacher Teacher @relation(fields: [tutor], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [topic], references: [id], onDelete: Cascade)

  @@id([tutor, topic])
}

model Schedule {
  id      String   @id @default(cuid())
  tutor   String
  day     Int
  start   String
  end     String
  repeat  Boolean  @default(true)
  active  Boolean  @default(true)
  created DateTime @default(now())
  updated DateTime @updatedAt

  teacher Teacher @relation(fields: [tutor], references: [id], onDelete: Cascade)
}

model Timeoff {
  id     String   @id @default(cuid())
  tutor  String
  start  DateTime
  end    DateTime
  reason String?

  teacher Teacher @relation(fields: [tutor], references: [id], onDelete: Cascade)
}

model Category {
  id    String  @id @default(cuid())
  slug  String  @unique
  name  String
  desc  String? @db.Text
  icon  String?
  group String?

  parent   Category?  @relation("Hierarchy", fields: [group], references: [id], onDelete: SetNull)
  children Category[] @relation("Hierarchy")
  courses  Course[]
}

model Tag {
  id      String   @id @default(cuid())
  slug    String   @unique
  name    String   @unique
  courses Course[]
}

model Course {
  id        String    @id @default(cuid())
  tutor     String
  group     String?
  slug      String    @unique
  code      String    @unique
  name      String
  desc      String?   @db.Text
  thumb     String?
  banner    String?
  video     String?
  level     Level     @default(ALL)
  lang      String    @default("vi")
  requires  String[]
  outcomes  String[]
  audience  String[]
  price     Decimal   @default(0.00) @db.Decimal(12, 2)
  sale      Decimal?  @db.Decimal(12, 2)
  cert      Boolean   @default(true)
  serial    Boolean   @default(false)
  duration  Int       @default(0)
  lessons   Int       @default(0)
  students  Int       @default(0)
  reviews   Int       @default(0)
  views     Int       @default(0)
  rating    Decimal   @default(0.00) @db.Decimal(3, 2)
  status    Status    @default(DRAFT)
  published DateTime?
  created   DateTime  @default(now())
  updated   DateTime  @updatedAt
  deleted   DateTime?

  teacher  Teacher   @relation(fields: [tutor], references: [id], onDelete: Restrict)
  category Category? @relation(fields: [group], references: [id], onDelete: SetNull)

  tags      Tag[]
  coupons   Coupon[]
  enrolls   Enrollment[]
  exams     Exam[]
  chapters  Chapter[]
  feedbacks Review[]
  favorites Favorite[]
  certs     Certificate[]
  items     Item[]
  picks     Selection[]
  faqs      Faq[]
  notices   Notice[]
  progress  Progress[]
}

model Faq {
  id       String   @id @default(cuid())
  core     String
  question String   @db.Text
  answer   String   @db.Text
  order    Int      @default(0)
  created  DateTime @default(now())
  updated  DateTime @updatedAt

  course Course @relation(fields: [core], references: [id], onDelete: Cascade)
}

model Notice {
  id      String   @id @default(cuid())
  core    String
  title   String
  content String   @db.Text
  created DateTime @default(now())
  updated DateTime @updatedAt

  course Course @relation(fields: [core], references: [id], onDelete: Cascade)
}

model Chapter {
  id      String    @id @default(cuid())
  core    String
  title   String
  order   Int       @default(0)
  access  Access    @default(ALL)
  created DateTime  @default(now())
  updated DateTime  @updatedAt
  deleted DateTime?

  course  Course   @relation(fields: [core], references: [id], onDelete: Cascade)
  lessons Lesson[]
}

model Lesson {
  id       String    @id @default(cuid())
  part     String
  test     String?   @unique
  title    String
  type     Format    @default(VIDEO)
  video    String?
  asset    Json?     @default("{}")
  status   Status    @default(PENDING)
  content  String?   @db.Text
  duration Int       @default(0)
  order    Int       @default(0)
  preview  Boolean   @default(false)
  created  DateTime  @default(now())
  updated  DateTime  @updatedAt
  deleted  DateTime?

  chapter  Chapter    @relation(fields: [part], references: [id], onDelete: Cascade)
  exam     Exam?      @relation(fields: [test], references: [id], onDelete: SetNull)
  progress Progress[]
  comments Comment[]
  tasks    Task[]
  media    Media[]
}

model Media {
  id        String   @id @default(cuid())
  unit      String
  name      String
  url       String
  size      Int      @default(0)
  type      String?
  downloads Int      @default(0)
  created   DateTime @default(now())

  lesson Lesson @relation(fields: [unit], references: [id], onDelete: Cascade)
}

model Comment {
  id       String    @id @default(cuid())
  learner  String
  unit     String
  node     String?
  content  String    @db.Text
  answered Boolean   @default(false)
  best     Boolean   @default(false)
  upvotes  Int       @default(0)
  created  DateTime  @default(now())
  updated  DateTime  @updatedAt
  deleted  DateTime?

  student Student   @relation(fields: [learner], references: [id], onDelete: Cascade)
  lesson  Lesson    @relation(fields: [unit], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("Tree", fields: [node], references: [id], onDelete: SetNull)
  replies Comment[] @relation("Tree")
  votes   Vote[]
}

model Vote {
  id      String   @id @default(cuid())
  learner String
  note    String
  upvote  Boolean  @default(true)
  created DateTime @default(now())

  student Student @relation(fields: [learner], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [note], references: [id], onDelete: Cascade)

  @@unique([learner, note])
}

model Task {
  id       String    @id @default(cuid())
  learner  String
  unit     String
  attempt  Int       @default(1)
  content  String?   @db.Text
  file     String?
  github   String?
  score    Float?
  feedback String?   @db.Text
  graded   DateTime?
  created  DateTime  @default(now())
  updated  DateTime  @updatedAt

  student Student @relation(fields: [learner], references: [id], onDelete: Cascade)
  lesson  Lesson  @relation(fields: [unit], references: [id], onDelete: Cascade)

  @@unique([learner, unit, attempt])
}

model Enrollment {
  id        String    @id @default(cuid())
  core      String
  learner   String
  status    Status    @default(ACTIVE)
  progress  Float     @default(0)
  completed DateTime?
  expire    DateTime?
  joined    DateTime  @default(now())
  updated   DateTime  @updatedAt

  course  Course  @relation(fields: [core], references: [id], onDelete: Cascade)
  student Student @relation(fields: [learner], references: [id], onDelete: Cascade)

  @@unique([core, learner])
}

model Progress {
  id      String   @id @default(cuid())
  learner String
  core    String
  unit    String
  done    Boolean  @default(false)
  watched Int      @default(0)
  updated DateTime @updatedAt

  student Student @relation(fields: [learner], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [core], references: [id], onDelete: Cascade)
  lesson  Lesson  @relation(fields: [unit], references: [id], onDelete: Cascade)

  @@unique([learner, unit])
}

model Favorite {
  id      String   @id @default(cuid())
  learner String
  core    String
  created DateTime @default(now())

  student Student @relation(fields: [learner], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [core], references: [id], onDelete: Cascade)

  @@unique([learner, core])
}

model Follow {
  id      String   @id @default(cuid())
  learner String
  tutor   String
  created DateTime @default(now())

  student Student @relation(fields: [learner], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [tutor], references: [id], onDelete: Cascade)

  @@unique([learner, tutor])
}

model Certificate {
  id      String   @id @default(cuid())
  code    String   @unique
  learner String
  core    String
  holder  String
  course  String
  url     String?
  issued  DateTime @default(now())

  student   Student @relation(fields: [learner], references: [id], onDelete: Cascade)
  courseRef Course  @relation(fields: [core], references: [id], onDelete: Cascade)

  @@unique([learner, core])
}

model Review {
  id      String   @id @default(cuid())
  learner String
  core    String?
  tutor   String?
  slot    String?  @unique
  rating  Int      @default(5)
  content String?  @db.Text
  reply   String?  @db.Text
  created DateTime @default(now())
  updated DateTime @updatedAt

  student Student  @relation(fields: [learner], references: [id], onDelete: Cascade)
  course  Course?  @relation(fields: [core], references: [id], onDelete: Cascade)
  teacher Teacher? @relation("TeacherReviews", fields: [tutor], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [slot], references: [id], onDelete: Cascade)
}

model Cart {
  id      String   @id @default(cuid())
  learner String   @unique
  created DateTime @default(now())
  updated DateTime @updatedAt

  student Student     @relation(fields: [learner], references: [id], onDelete: Cascade)
  picks   Selection[]
}

model Selection {
  id      String   @id @default(cuid())
  cart    String
  core    String
  created DateTime @default(now())

  basket Cart   @relation(fields: [cart], references: [id], onDelete: Cascade)
  course Course @relation(fields: [core], references: [id], onDelete: Cascade)

  @@unique([cart, core])
}

model Coupon {
  id       String   @id @default(cuid())
  tutor    String?
  code     String   @unique
  method   Method   @default(PERCENTAGE)
  value    Decimal  @db.Decimal(12, 2)
  minimum  Decimal? @db.Decimal(12, 2)
  maximum  Decimal? @db.Decimal(12, 2)
  limit    Int?
  capacity Int?     @default(1)
  used     Int      @default(0)
  active   Boolean  @default(true)
  start    DateTime
  end      DateTime
  created  DateTime @default(now())
  updated  DateTime @updatedAt

  teacher Teacher? @relation(fields: [tutor], references: [id], onDelete: Cascade)
  courses Course[]
  orders  Order[]
  usages  Usage[]
}

model Usage {
  id    String   @id @default(cuid())
  owner String
  card  String
  bill  String
  used  DateTime @default(now())

  user   User   @relation(fields: [owner], references: [id], onDelete: Restrict)
  coupon Coupon @relation(fields: [card], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [bill], references: [id], onDelete: Cascade)

  @@unique([owner, card, bill])
}

model Order {
  id       String   @id @default(cuid())
  owner    String
  card     String?
  code     String   @unique
  type     Type     @default(PURCHASE)
  amount   Decimal  @db.Decimal(12, 2)
  discount Decimal  @default(0.00) @db.Decimal(12, 2)
  final    Decimal  @db.Decimal(12, 2)
  status   Status   @default(PENDING)
  gateway  String   @default("VNPAY")
  txn      String?
  hash     String?  @unique
  created  DateTime @default(now())
  updated  DateTime @updatedAt

  user   User     @relation(fields: [owner], references: [id], onDelete: Restrict)
  coupon Coupon?  @relation(fields: [card], references: [id], onDelete: SetNull)
  items  Item[]
  down   Booking? @relation("DownOrder")
  tail   Booking? @relation("TailOrder")
  usages Usage[]
}

model Item {
  id      String   @id @default(cuid())
  bill    String
  core    String
  price   Decimal  @db.Decimal(12, 2)
  name    String
  income  Decimal  @default(0.00) @db.Decimal(12, 2)
  fee     Decimal  @default(0.00) @db.Decimal(12, 2)
  paid    Boolean  @default(false)
  created DateTime @default(now())

  order  Order  @relation(fields: [bill], references: [id], onDelete: Cascade)
  course Course @relation(fields: [core], references: [id], onDelete: Restrict)

  @@unique([bill, core])
}

model Post {
  id      String   @id @default(cuid())
  tutor   String
  title   String
  content String   @db.Text
  type    String
  subject String
  budget  Decimal  @db.Decimal(12, 2)
  created DateTime @default(now())
  updated DateTime @updatedAt

  teacher Teacher @relation(fields: [tutor], references: [id], onDelete: Cascade)
  bids    Bid[]
}

model Bid {
  id      String   @id @default(cuid())
  job     String
  tutor   String
  cover   String   @db.Text
  rate    Decimal  @db.Decimal(12, 2)
  status  Status   @default(PENDING)
  created DateTime @default(now())

  post    Post    @relation(fields: [job], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [tutor], references: [id], onDelete: Cascade)

  @@unique([job, tutor])
}

model Booking {
  id         String    @id @default(cuid())
  tutor      String
  learner    String
  downId     String?   @unique
  tailId     String?   @unique
  start      DateTime?
  end        DateTime?
  schedule   String?
  online     Boolean   @default(true)
  meet       String?
  status     Status    @default(PENDING)
  total      Decimal   @db.Decimal(12, 2)
  fee        Decimal   @db.Decimal(12, 2)
  income     Decimal   @db.Decimal(12, 2)
  deposit    Boolean   @default(false)
  final      Boolean   @default(false)
  paid       Boolean   @default(false)
  canceller  String?
  reason     String?   @db.Text
  reschedule Json?     @default("[]")
  created    DateTime  @default(now())
  updated    DateTime  @updatedAt

  teacher Teacher @relation("TeacherBookings", fields: [tutor], references: [id], onDelete: Cascade)
  student Student @relation("StudentBookings", fields: [learner], references: [id], onDelete: Cascade)
  down    Order?  @relation("DownOrder", fields: [downId], references: [id], onDelete: SetNull)
  tail    Order?  @relation("TailOrder", fields: [tailId], references: [id], onDelete: SetNull)
  review  Review?
  report  Report?
}

model Chat {
  id      String   @id @default(cuid())
  user1   String
  user2   String
  created DateTime @default(now())
  updated DateTime @updatedAt

  first    User      @relation("UserOne", fields: [user1], references: [id], onDelete: Cascade)
  second   User      @relation("UserTwo", fields: [user2], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([user1, user2])
}

model Message {
  id      String   @id @default(cuid())
  room    String
  sender  String
  content String   @db.Text
  file    String?
  read    Boolean  @default(false)
  created DateTime @default(now())

  chat Chat @relation(fields: [room], references: [id], onDelete: Cascade)
  user User @relation(fields: [sender], references: [id], onDelete: Cascade)
}

model Report {
  id       String   @id @default(cuid())
  creator  String
  target   String
  slot     String?  @unique
  reason   String   @db.Text
  evidence String?
  status   Status   @default(PENDING)
  created  DateTime @default(now())
  updated  DateTime @updatedAt

  author  User     @relation("Creator", fields: [creator], references: [id], onDelete: Cascade)
  victim  User     @relation("Target", fields: [target], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [slot], references: [id], onDelete: Cascade)
}

model Bank {
  id      String    @id @default(cuid())
  tutor   String
  name    String
  subject String
  desc    String?   @db.Text
  public  Boolean   @default(false)
  created DateTime  @default(now())
  updated DateTime  @updatedAt
  deleted DateTime?

  teacher   Teacher    @relation(fields: [tutor], references: [id], onDelete: Cascade)
  questions Question[]
}

model Question {
  id       String    @id @default(cuid())
  vault    String
  content  String    @db.Text
  type     String    @default("MCQ")
  level    String    @default("MEDIUM")
  topic    String?
  options  Json?
  solution Json?
  points   Float     @default(1.0)
  active   Boolean   @default(true)
  created  DateTime  @default(now())
  updated  DateTime  @updatedAt
  deleted  DateTime?

  bank  Bank   @relation(fields: [vault], references: [id], onDelete: Cascade)
  tests Test[]
}

model Exam {
  id        String    @id @default(cuid())
  tutor     String
  core      String?
  title     String
  desc      String?   @db.Text
  duration  Int
  threshold Float     @default(5.0)
  config    Json      @default("{}")
  status    String    @default("DRAFT")
  start     DateTime?
  end       DateTime?
  created   DateTime  @default(now())
  updated   DateTime  @updatedAt
  deleted   DateTime?

  teacher Teacher      @relation(fields: [tutor], references: [id], onDelete: Cascade)
  course  Course?      @relation(fields: [core], references: [id], onDelete: SetNull)
  lesson  Lesson?
  subs    Submission[]
  tests   Test[]
}

model Test {
  id     String @id @default(cuid())
  test   String
  quiz   String
  order  Int    @default(0)
  points Float  @default(1.0)

  exam     Exam     @relation(fields: [test], references: [id], onDelete: Cascade)
  question Question @relation(fields: [quiz], references: [id], onDelete: Cascade)

  @@unique([test, quiz])
}

model Submission {
  id       String    @id @default(cuid())
  test     String
  learner  String
  attempt  Int       @default(1)
  start    DateTime  @default(now())
  submit   DateTime?
  elapsed  Int       @default(0)
  cheats   Int       @default(0)
  logs     Json?     @default("[]")
  answers  Json?     @default("[]")
  score    Float     @default(0)
  max      Float     @default(10.0)
  passed   Boolean   @default(false)
  feedback String?   @db.Text
  graded   DateTime?
  status   Status    @default(PENDING)
  created  DateTime  @default(now())
  updated  DateTime  @updatedAt

  exam    Exam    @relation(fields: [test], references: [id], onDelete: Cascade)
  student Student @relation(fields: [learner], references: [id], onDelete: Cascade)

  @@unique([test, learner, attempt])
}

model Plan {
  id        String    @id @default(cuid())
  learner   String
  title     String
  subject   String?
  content   Json
  status    Status    @default(ACTIVE)
  completed DateTime?
  created   DateTime  @default(now())
  updated   DateTime  @updatedAt

  student Student @relation(fields: [learner], references: [id], onDelete: Cascade)
}

model Notification {
  id       String    @id @default(cuid())
  owner    String
  title    String
  message  String?   @db.Text
  type     String    @default("SYSTEM")
  priority Int       @default(1)
  read     Boolean   @default(false)
  opened   DateTime?
  expired  DateTime?
  created  DateTime  @default(now())

  user User @relation(fields: [owner], references: [id], onDelete: Cascade)
}

model Audit {
  id      String   @id @default(cuid())
  actor   String
  action  String
  entity  String
  target  String
  old     Json?
  new     Json?
  ip      String?
  created DateTime @default(now())

  user User @relation(fields: [actor], references: [id], onDelete: Cascade)
}
