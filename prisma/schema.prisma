datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  STUDENT
  TUTOR
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Mode {
  ONLINE
  OFFLINE
}

enum Level {
  PRIMARY
  MIDDLE
  HIGH
  ALL
}

enum State {
  PENDING
  VERIFIED
  REJECTED
  OPEN
  ACTIVE
  DONE
  FAILED
  CANCEL
  HOLD
  RELEASE
  REFUND
  DISPUTE
}

enum Type {
  DEPOSIT
  PAYMENT
  PAYOUT
  COMMISSION
  PENALTY
}

enum Phase {
  FIRST
  FINAL
  FULL
}

enum Kind {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

model User {
  id       String    @id @default(cuid())
  email    String    @unique
  password String
  name     String
  alias    String?
  dob      DateTime?
  role     Role      @default(STUDENT)
  gender   Gender    @default(OTHER)
  avatar   String?
  phone    String?
  login    DateTime?
  token    String?
  expire   DateTime?
  attempts Int       @default(0)
  blocked  DateTime?
  secured  Boolean   @default(false)
  secret   String?
  provider String    @default("credentials")
  active   Boolean   @default(true)
  created  DateTime  @default(now())
  updated  DateTime  @updatedAt
  deleted  DateTime?

  student Student?
  tutor   Tutor?

  banks       Bank[]
  notices     Notice[]
  firsts      Chat[]       @relation("One")
  seconds     Chat[]       @relation("Two")
  attachments Attachment[]
  messages    Message[]
  claims      Report[]     @relation("Creator")
  charges     Report[]     @relation("Target")
  audits      Audit[]
  payments    Payment[]

  @@index([role, active])
  @@index([created])
}

model Student {
  id       String   @id @default(cuid())
  user     String   @unique
  city     String?
  district String?
  ward     String?
  street   String?
  lat      Float?
  lng      Float?
  created  DateTime @default(now())
  updated  DateTime @updatedAt

  account User @relation(fields: [user], references: [id], onDelete: Cascade)

  needs   Request[]
  deals   Contract[]
  reviews Review[]
  follows Follow[]

  @@index([city, district])
}

model Tutor {
  id       String   @id @default(cuid())
  user     String   @unique
  bio      String?  @db.Text
  idcard   String?  @unique
  level    String?
  major    String?
  school   String?
  exp      Int      @default(0)
  status   State    @default(PENDING)
  rate     Decimal  @default(0.00) @db.Decimal(12, 2)
  modes    Mode[]
  city     String?
  district String?
  ward     String?
  street   String?
  lat      Float?
  lng      Float?
  rating   Decimal  @default(0.00) @db.Decimal(3, 2)
  reviews  Int      @default(0)
  created  DateTime @default(now())
  updated  DateTime @updatedAt

  account User @relation(fields: [user], references: [id], onDelete: Cascade)

  skills  Skill[]
  slots   Schedule[]
  posts   Post[]
  bids    Bid[]
  deals   Contract[]
  rates   Review[]
  follows Follow[]
  degrees Degree[]
  jobs    History[]
  marks   Bookmark[]

  @@index([status, rating])
  @@index([city, district])
  @@index([exp])
}

model Bank {
  id      String   @id @default(cuid())
  owner   String
  name    String
  number  String
  holder  String
  branch  String?
  primary Boolean  @default(false)
  created DateTime @default(now())
  updated DateTime @updatedAt

  user  User      @relation(fields: [owner], references: [id], onDelete: Cascade)
  bills Payment[]
}

model Degree {
  id      String   @id @default(cuid())
  owner   String
  name    String
  type    String
  score   String?
  issuer  String?
  year    Int?
  url     String
  status  State    @default(PENDING)
  created DateTime @default(now())

  tutor Tutor @relation(fields: [owner], references: [id], onDelete: Cascade)

  @@index([owner, status])
}

model History {
  id      String   @id @default(cuid())
  owner   String
  title   String
  place   String
  start   Int
  end     Int?
  desc    String?  @db.Text
  created DateTime @default(now())

  tutor Tutor @relation(fields: [owner], references: [id], onDelete: Cascade)

  @@index([owner])
}

model Subject {
  id     String    @id @default(cuid())
  name   String    @unique
  slug   String    @unique
  skills Skill[]
  needs  Request[]
  posts  Post[]
}

model Skill {
  owner  String
  topic  String
  grades Int[]

  tutor   Tutor   @relation(fields: [owner], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [topic], references: [id], onDelete: Cascade)

  @@id([owner, topic])
  @@index([topic])
}

model Post {
  id       String   @id @default(cuid())
  owner    String
  topic    String
  title    String
  content  String   @db.Text
  level    Level    @default(ALL)
  grade    Int
  mode     Mode
  city     String?
  district String?
  ward     String?
  street   String?
  lat      Float?
  lng      Float?
  price    Decimal  @db.Decimal(12, 2)
  status   State    @default(OPEN)
  created  DateTime @default(now())
  updated  DateTime @updatedAt

  tutor   Tutor      @relation(fields: [owner], references: [id], onDelete: Cascade)
  subject Subject    @relation(fields: [topic], references: [id], onDelete: Restrict)
  deals   Contract[]

  @@index([topic, status])
  @@index([city, district])
  @@index([level, grade])
  @@index([price])
}

model Request {
  id       String   @id @default(cuid())
  learner  String
  topic    String
  title    String
  desc     String   @db.Text
  level    Level    @default(ALL)
  grade    Int
  mode     Mode
  city     String?
  district String?
  ward     String?
  street   String?
  lat      Float?
  lng      Float?
  budget   Decimal  @db.Decimal(12, 2)
  count    Int      @default(1)
  schedule String?
  status   State    @default(OPEN)
  created  DateTime @default(now())
  updated  DateTime @updatedAt

  student Student    @relation(fields: [learner], references: [id], onDelete: Cascade)
  subject Subject    @relation(fields: [topic], references: [id], onDelete: Restrict)
  bids    Bid[]
  deal    Contract?
  marks   Bookmark[]

  @@index([topic, status])
  @@index([city, district])
  @@index([level, grade])
  @@index([budget])
}

model Bookmark {
  id      String   @id @default(cuid())
  owner   String
  need    String
  created DateTime @default(now())

  tutor   Tutor   @relation(fields: [owner], references: [id], onDelete: Cascade)
  request Request @relation(fields: [need], references: [id], onDelete: Cascade)

  @@unique([owner, need])
  @@index([owner])
}

model Bid {
  id      String   @id @default(cuid())
  need    String
  owner   String
  price   Decimal  @db.Decimal(12, 2)
  cover   String   @db.Text
  status  State    @default(PENDING)
  created DateTime @default(now())
  updated DateTime @updatedAt

  request Request @relation(fields: [need], references: [id], onDelete: Cascade)
  tutor   Tutor   @relation(fields: [owner], references: [id], onDelete: Cascade)

  @@unique([need, owner])
  @@index([status])
}

model Contract {
  id      String   @id @default(cuid())
  code    String   @unique
  learner String
  tutor   String
  need    String?  @unique
  post    String?
  title   String
  total   Decimal  @db.Decimal(12, 2)
  fee     Decimal  @db.Decimal(12, 2)
  income  Decimal  @db.Decimal(12, 2)
  count   Int
  status  State    @default(PENDING)
  escrow  State    @default(HOLD)
  reason  String?  @db.Text
  created DateTime @default(now())
  updated DateTime @updatedAt

  student Student  @relation(fields: [learner], references: [id], onDelete: Restrict)
  teacher Tutor    @relation(fields: [tutor], references: [id], onDelete: Restrict)
  request Request? @relation(fields: [need], references: [id], onDelete: SetNull)
  class   Post?    @relation(fields: [post], references: [id], onDelete: SetNull)

  items   Session[]
  bills   Payment[]
  reviews Review[]
  clashes Dispute[]

  @@index([status, escrow])
  @@index([learner, tutor])
  @@index([created])
}

model Session {
  id       String    @id @default(cuid())
  deal     String
  title    String
  start    DateTime
  end      DateTime
  status   State     @default(PENDING)
  summary  String?   @db.Text
  feedback String?   @db.Text
  verify   DateTime?
  created  DateTime  @default(now())
  updated  DateTime  @updatedAt

  contract Contract @relation(fields: [deal], references: [id], onDelete: Cascade)
  reports  Report[]

  @@index([deal, status])
}

model Dispute {
  id      String   @id @default(cuid())
  deal    String
  creator String
  reason  String   @db.Text
  proof   String?
  status  State    @default(OPEN)
  note    String?  @db.Text
  created DateTime @default(now())
  updated DateTime @updatedAt

  contract Contract @relation(fields: [deal], references: [id], onDelete: Cascade)

  @@index([status])
}

model Payment {
  id      String   @id @default(cuid())
  code    String   @unique
  owner   String
  deal    String?
  vault   String?
  type    Type
  phase   Phase?
  amount  Decimal  @db.Decimal(12, 2)
  desc    String
  status  State    @default(PENDING)
  gateway String?
  ref     String?
  created DateTime @default(now())

  user     User      @relation(fields: [owner], references: [id], onDelete: Restrict)
  contract Contract? @relation(fields: [deal], references: [id], onDelete: SetNull)
  bank     Bank?     @relation(fields: [vault], references: [id], onDelete: SetNull)

  @@index([owner, status])
  @@index([type, phase])
  @@index([created])
}

model Schedule {
  id     String  @id @default(cuid())
  owner  String
  day    Int
  start  String
  end    String
  active Boolean @default(true)

  tutor Tutor @relation(fields: [owner], references: [id], onDelete: Cascade)

  @@index([owner, day, active])
}

model Review {
  id      String   @id @default(cuid())
  learner String
  tutor   String
  deal    String   @unique
  rating  Int      @default(5)
  content String?  @db.Text
  reply   String?  @db.Text
  created DateTime @default(now())

  student  Student  @relation(fields: [learner], references: [id], onDelete: Cascade)
  teacher  Tutor    @relation(fields: [tutor], references: [id], onDelete: Cascade)
  contract Contract @relation(fields: [deal], references: [id], onDelete: Cascade)

  @@index([tutor, rating])
}

model Follow {
  id      String   @id @default(cuid())
  learner String
  tutor   String
  created DateTime @default(now())

  student Student @relation(fields: [learner], references: [id], onDelete: Cascade)
  teacher Tutor   @relation(fields: [tutor], references: [id], onDelete: Cascade)

  @@unique([learner, tutor])
  @@index([learner])
}

model Chat {
  id      String    @id @default(cuid())
  first   String
  second  String
  read1   DateTime?
  read2   DateTime?
  created DateTime  @default(now())
  updated DateTime  @updatedAt

  user1    User      @relation("One", fields: [first], references: [id], onDelete: Cascade)
  user2    User      @relation("Two", fields: [second], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([first, second])
}

model Message {
  id      String   @id @default(cuid())
  room    String
  sender  String
  kind    Kind     @default(TEXT)
  content String?  @db.Text
  attach  String?  @unique
  created DateTime @default(now())

  chat       Chat        @relation(fields: [room], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [sender], references: [id], onDelete: Cascade)
  attachment Attachment? @relation(fields: [attach], references: [id], onDelete: SetNull)

  @@index([room, created])
}

model Attachment {
  id      String   @id @default(cuid())
  owner   String
  name    String
  mime    String
  size    Int
  url     String
  created DateTime @default(now())

  user    User     @relation(fields: [owner], references: [id], onDelete: Cascade)
  message Message?

  @@index([owner])
}

model Report {
  id      String   @id @default(cuid())
  creator String
  target  String
  item    String?
  reason  String   @db.Text
  proof   String?
  status  State    @default(PENDING)
  created DateTime @default(now())

  author  User     @relation("Creator", fields: [creator], references: [id], onDelete: Cascade)
  victim  User     @relation("Target", fields: [target], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [item], references: [id], onDelete: SetNull)

  @@index([status])
}

model Notice {
  id      String   @id @default(cuid())
  owner   String
  title   String
  content String   @db.Text
  link    String?
  read    Boolean  @default(false)
  created DateTime @default(now())

  user User @relation(fields: [owner], references: [id], onDelete: Cascade)

  @@index([owner, read])
  @@index([owner, created])
}

model Audit {
  id      String   @id @default(cuid())
  actor   String
  action  String
  entity  String
  target  String
  old     Json?
  new     Json?
  ip      String?
  created DateTime @default(now())

  user User @relation(fields: [actor], references: [id], onDelete: Cascade)

  @@index([entity, target])
  @@index([created])
}
